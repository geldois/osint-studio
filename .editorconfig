root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[Makefile]
indent_style = tab

[*.css]
indent_size = 2

[Dockerfile]
indent_size = 2

[*.{gitattributes,gitconfig,gitignore}]
indent_size = 2

[*.{htm,html}]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_size = 2

[*.toml]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2
